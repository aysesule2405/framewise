# ── Database ──────────────────────────────────────────────────────────────────
MONGODB_URI=your_mongodb_atlas_connection_string
# Atlas auto-creates text indexes when the app first starts (development).
# In production, create the index manually if autoIndex is disabled:
#   db.videos.createIndex({ title: "text", transcript: "text", segmentSearchText: "text" },
#                         { weights: { title: 8, segmentSearchText: 5, transcript: 1 } })

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=any_long_random_string_at_least_32_chars
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret

# ── AI / Voice ────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key
# Optional: comma-separated list of model names to try in order
# GEMINI_MODEL=gemini-2.5-flash-lite,gemini-2.5-flash

# Max Gemini requests per 60 s across the entire app (all users, all features).
# Free tier: flash-lite = 15 RPM, flash = 10 RPM. 14 is the default (flash-lite ceiling minus one).
# Drop to 10 if you are on flash model only.
GEMINI_RPM=14

# Number of video chunks processed in parallel per analysis call.
# 3 is the default — good balance of speed and quota headroom.
# Drop to 1 only if you're hitting quota on very long videos.
GEMINI_CHUNK_CONCURRENCY=3

ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_ID=your_elevenlabs_voice_id
# Optional second voice used by Settings → Coach voice.
ELEVENLABS_COACH_VOICE_ID=your_second_elevenlabs_voice_id

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
# In production set NODE_ENV=production and list every allowed web-app origin:
ALLOWED_ORIGINS=http://localhost:5174
# Production example: ALLOWED_ORIGINS=https://app.framewise.io,https://framewise.io
