# ── Google OAuth ──────────────────────────────────────────────────────────────
# Required for Google sign-in. Get from Google Cloud Console → OAuth 2.0 credentials.
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id

# ── API ───────────────────────────────────────────────────────────────────────
# In development the Vite proxy (vite.config.js) forwards /api → http://localhost:3001.
# In production point this at your deployed backend and update vite.config.js accordingly.
# VITE_API_BASE_URL=https://api.framewise.io
